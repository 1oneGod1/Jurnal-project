# Cloudflare R2 Configuration
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_ACCESS_KEY_ID=your_access_key_id_here
CLOUDFLARE_SECRET_ACCESS_KEY=your_secret_access_key_here
CLOUDFLARE_BUCKET_NAME=jurnal-proyek-dokumentasi
CLOUDFLARE_PUBLIC_URL=https://jurnal-docs.com

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration (separate multiple origins with comma)
CORS_ORIGIN=http://localhost:5173,http://localhost:3001
